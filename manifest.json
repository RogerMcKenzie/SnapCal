{
  "manifest_version": 3,
  "name": "SnapCal",
  "version": "1.0.0",
  "description": "Extract event details from any page and create Google Calendar events with AI.",
  "permissions": [
    "activeTab",
    "storage",
    "identity",
    "scripting"
  ],
  "host_permissions": [
    "https://snapcal-proxy.vercel.app/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.ts"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/index.html",
  "oauth2": {
    "client_id": "1079636021022-72p2ikr4dko4e11kvpc75j2b3l2k6244.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "snap_analyze": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Snap page and analyze with AI"
    }
  }
}